{
  "extends": "./tsconfig.json",
  "include": ["gateway/**/*.ts"],
  "compilerOptions": {
    "declaration": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext"
  }
}
